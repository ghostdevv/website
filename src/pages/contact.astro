---
import IconMastodon from '~icons/custom/mastodon';
import IconBluesky from '~icons/custom/bluesky';
import IconDiscord from '~icons/custom/discord';
import IconGitHub from '~icons/lucide/github';
import IconX from '~icons/custom/twitter-x';
import Page from '$lib/layouts/Page.astro';
import IconMail from '~icons/lucide/mail';
---

<Page>
	<section class="column g4">
		<h1>Contact</h1>

		<p class="row">
			<IconDiscord />
			<a
				target="_blank"
				href="https://discord.com/users/282839711834177537"
			>
				Discord (@willow_ghost)
			</a>
		</p>

		<p class="row">
			<IconMail />
			<a target="_blank" href="mailto:ghostdevbusiness@gmail.com">
				ghostdevbusiness@gmail.com
			</a>
		</p>
	</section>

	<section class="column g4">
		<h1>Links</h1>

		<p class="row">
			<IconBluesky />
			<a target="_blank" href="https://bsky.app/profile/willow.sh">
				@willow.sh
			</a>
		</p>

		<p class="row">
			<IconGitHub />
			<a target="_blank" href="https://github.com/ghostdevv">ghostdevv</a>
		</p>

		<p class="row">
			<IconMastodon />
			<a target="_blank" href="https://fosstodon.org/@onlyspaceghost">
				@onlyspaceghost@fosstodon.org
			</a>
		</p>

		<p class="row">
			<IconX />
			<a target="_blank" href="https://x.com/onlyspaceghost">
				@onlyspaceghost
			</a>
		</p>
	</section>
</Page>

<style lang="scss">
	@use 'include-media' as *;

	.devlounge {
		position: fixed;
		bottom: 32px;
		left: 50%;
		transform: translateX(-50%);

		width: calc(100% - 64px);
		max-width: 1400px;
		margin: 0 auto;

		.card {
			border-color: #cf4a4a;

			flex-direction: row;
			align-items: center;

			margin: 0 auto;

			@include media('<500px') {
				flex-direction: column;
				text-align: center;

				.meta {
					text-align: center;
					align-items: center;
				}
			}
		}
	}
</style>
